{
  "name": "sentinel-centralized-cron",
  "version": "0.1.0",
  "private": true,
  "description": "Centralized TypeScript cron that simulates the Chainlink CRE workflow for Sentinel Protocol on Avalanche Fuji.",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "tick": "ts-node src/workflow.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "viem": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}

