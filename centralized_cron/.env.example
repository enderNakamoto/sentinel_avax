AVAX_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# 0x-prefixed private key for the workflow signer EOA.
# This address must be funded with Fuji AVAX and wired on-chain as:
# - OracleAggregator.setOracle(workflowEOA)   (one-time)
# - Controller.setCreWorkflow(workflowEOA)    (owner-only, updatable)
WORKFLOW_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Deployed contract addresses on Fuji
ORACLE_AGGREGATOR_ADDRESS=0x14cF0CD23B5A444f1e57765d12f21ee7F1e8a2c3
CONTROLLER_ADDRESS=0xd67c1b05Cdfa20aa23C295a2c24310763fED4888

# FlightAware AeroAPI configuration
AEROAPI_KEY=your-aeroapi-key
AEROAPI_BASE_URL=https://aeroapi.flightaware.com/aeroapi

# Cron schedule for node-cron (default: every 10 minutes)
# See https://github.com/node-cron/node-cron for syntax.
CRON_SCHEDULE=*/10 * * * *

