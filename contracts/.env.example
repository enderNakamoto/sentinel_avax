# Deployer private key (include 0x prefix)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Snowtrace / Routescan API key — https://snowtrace.io/myapikey
SNOWTRACE_API_KEY=YOUR_SNOWTRACE_API_KEY

# Avalanche RPC endpoints
AVAX_FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc
AVAX_MAINNET_RPC=https://api.avax.network/ext/bc/C/rpc

# --- Set after running Deploy.s.sol ---
MOCK_USDC_ADDRESS=0x
GOVERNANCE_ADDRESS=0x
RECOVERY_POOL_ADDRESS=0x
ORACLE_AGGREGATOR_ADDRESS=0x
RISK_VAULT_ADDRESS=0x
CONTROLLER_ADDRESS=0x

# --- Workflow signer EOA ---
# The address that will be wired as oracle writer + CRE workflow caller.
# For Stage 2 (centralized cron): set to the EOA whose private key is in
#   centralized_cron/.env as WORKFLOW_PRIVATE_KEY.
# For Stage 3 (CRE DON): update to the forwarder from `cre workflow info`.
WORKFLOW_SIGNER_ADDRESS=0x

# --- Set after deploying CRE workflow (cre workflow info <id>) ---
# Used by WireCRE.s.sol to call setOracle() and setCreWorkflow()
CRE_WORKFLOW_ADDRESS=0x
