# CRE workflow local simulation environment variables.
# Copy to .env and fill in your values.
# This file is committed. .env is gitignored.
#
# During `cre workflow simulate`, the SDK reads secrets from this file via
# runtime.getSecret("AEROAPI_KEY"). For DON deployment, set the secret with:
#   cre secrets set AEROAPI_KEY --value "your-key"

# AeroAPI (FlightAware) key — get yours at https://flightaware.com/commercial/aeroapi/
AEROAPI_KEY=your_flightaware_aeroapi_key_here

# CRE signer wallet — used to sign broadcast transactions during simulation.
# This address must be wired on-chain before running the simulation:
#   cast send $ORACLE_AGGREGATOR_ADDRESS "setOracle(address)" <CRE_SIGNER_ADDRESS> ...
#   cast send $CONTROLLER_ADDRESS "setCreWorkflow(address)" <CRE_SIGNER_ADDRESS> ...
# Derive address: cast wallet address --private-key $CRE_ETH_PRIVATE_KEY
CRE_ETH_PRIVATE_KEY=0x_your_testnet_private_key_here

# Fuji RPC endpoint — used by the CRE CLI for EVM reads and broadcast writes
AVAX_FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc
