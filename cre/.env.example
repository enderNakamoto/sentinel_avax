# CRE workflow local simulation environment variables.
# Copy to .env and fill in your values.
# This file is committed. .env is gitignored.
#
# During `cre workflow simulate`, the SDK reads secrets from this file via
# runtime.getSecret("AEROAPI_KEY"). For DON deployment, set the secret with:
#   cre secrets set AEROAPI_KEY --value "your-key"

# AeroAPI (FlightAware) key — get yours at https://flightaware.com/commercial/aeroapi/
AEROAPI_KEY=your_flightaware_aeroapi_key_here
